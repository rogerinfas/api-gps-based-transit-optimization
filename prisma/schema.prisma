// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model Route {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  description   String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  routeStops    RouteStop[]
  vehicles      Vehicle[]
  etaPredictions EtaPrediction[]

  @@index([isActive])
}

model Stop {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  latitude       Decimal         @db.Decimal(9, 6)
  longitude      Decimal         @db.Decimal(9, 6)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  routeStops     RouteStop[]
  etaPredictions EtaPrediction[]

  @@index([isActive])
}

model RouteStop {
  routeId                     String
  stopId                      String
  stopOrder                   Int
  distanceFromRouteStartMeters Int?
  plannedTravelSeconds        Int?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  route                       Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop                        Stop     @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@id([routeId, stopId])
  @@unique([routeId, stopOrder])
  @@index([stopId])
}

model Vehicle {
  id             String          @id @default(cuid())
  code           String          @unique
  plateNumber    String?         @unique
  status         VehicleStatus   @default(ACTIVE)
  capacity       Int?
  routeId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  route          Route?          @relation(fields: [routeId], references: [id], onDelete: SetNull)
  gpsPositions   GpsPosition[]
  etaPredictions EtaPrediction[]

  @@index([status])
  @@index([routeId])
}

model GpsPosition {
  id             String    @id @default(cuid())
  vehicleId      String
  latitude       Decimal   @db.Decimal(9, 6)
  longitude      Decimal   @db.Decimal(9, 6)
  speedKph       Decimal?  @db.Decimal(5, 2)
  headingDegrees Decimal?  @db.Decimal(5, 2)
  recordedAt     DateTime
  createdAt      DateTime  @default(now())
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, recordedAt(sort: Desc)])
}

model EtaPrediction {
  id                 String    @id @default(cuid())
  vehicleId          String
  routeId            String
  stopId             String
  etaSeconds         Int
  predictedArrivalAt DateTime
  confidence         Decimal?  @db.Decimal(5, 2)
  calculatedAt       DateTime  @default(now())
  createdAt          DateTime  @default(now())
  vehicle            Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  route              Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop               Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@index([vehicleId, calculatedAt(sort: Desc)])
  @@index([routeId, stopId, predictedArrivalAt])
}
